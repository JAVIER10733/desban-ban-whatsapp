{
  "name": "desban-ban-whatsapp",
  "version": "1.0.0",
  "description": "Plataforma profesional de desbaneo y baneo de números de WhatsApp",
  "private": true,
  "author": {
    "name": "DesbanWA Team",
    "email": "dev@desbanwa.com"
  },
  "license": "MIT",
  "homepage": "https://desbanwa.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/desbanwa/desban-ban-whatsapp.git"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev":          "npx serve . --listen 3000 --single",
    "start":        "npm run dev",
    "build":        "echo 'Proyecto estático — sin build requerido'",
    "preview":      "npx serve . --listen 4000",
    "lint":         "eslint 'modules/**/*.js' 'netlify/**/*.js' --fix",
    "lint:css":     "stylelint 'modules/**/*.css' --fix",
    "lint:all":     "npm run lint && npm run lint:css",
    "format":       "prettier --write 'modules/**/*.{html,css,js,json}' 'netlify/**/*.js'",
    "test":         "jest --passWithNoTests",
    "test:watch":   "jest --watch",
    "test:coverage":"jest --coverage",
    "test:e2e":     "playwright test",
    "test:e2e:ui":  "playwright test --ui",
    "db:migrate":   "node scripts/db-migrate.js",
    "db:seed":      "node scripts/db-seed.js",
    "db:reset":     "node scripts/db-reset.js",
    "validate":     "npm run lint:all && npm run test",
    "prepare":      "echo 'Listo para desarrollo'"
  },
  "dependencies": {
    "@netlify/functions": "^2.6.0",
    "nodemailer":         "^6.9.13",
    "stripe":             "^16.2.0",
    "pg":                 "^8.12.0",
    "bcryptjs":           "^2.4.3",
    "jsonwebtoken":       "^9.0.2",
    "express-rate-limit": "^7.3.1",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "zod":                "^3.23.8"
  },
  "devDependencies": {
    "eslint":                      "^9.6.0",
    "eslint-config-prettier":      "^9.1.0",
    "prettier":                    "^3.3.3",
    "stylelint":                   "^16.7.0",
    "stylelint-config-standard":   "^36.0.1",
    "jest":                        "^29.7.0",
    "@jest/globals":               "^29.7.0",
    "jest-environment-node":       "^29.7.0",
    "@playwright/test":            "^1.45.3",
    "serve":                       "^14.2.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/modules/**/tests/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "modules/**/*.js",
      "netlify/functions/**/*.js",
      "!**/node_modules/**"
    ]
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2022": true,
      "node":    true
    },
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType":  "module"
    },
    "rules": {
      "no-console":    "warn",
      "no-unused-vars":"warn",
      "eqeqeq":        "error"
    }
  },
  "prettier": {
    "semi":         true,
    "singleQuote":  true,
    "tabWidth":     2,
    "trailingComma":"es5",
    "printWidth":   100
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "keywords": [
    "whatsapp",
    "desbaneo",
    "baneo",
    "whatsapp-unban",
    "whatsapp-ban",
    "netlify",
    "serverless"
  ]
}